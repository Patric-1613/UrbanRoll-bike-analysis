      <aliases enabled='yes' />
      <column caption='Ride Category' datatype='string' name='[Calculation_5633260301918208]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEDIFF(&apos;minute&apos;,[start_time],[end_time]) &lt;= 10 THEN &quot;Short (0-10 min)&quot;&#10;ELSEIF DATEDIFF(&apos;minute&apos;,[start_time],[end_time]) &lt;= 30 THEN &quot;Medium (11-30 min)&quot;&#10;ELSE &quot;Long (30+ min)&quot;&#10;END' />
      </column>
      <column caption='Trip_duration (mins)' datatype='integer' name='[Calculation_5633260626141187]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;minute&apos;, [start_time], [end_time])' />
      </column>
      <column caption='Net_flow' datatype='integer' name='[Calculation_5633260642177028]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [end_station_id] : COUNT([ride_id]) } -&#10;{ FIXED [start_station_id] : COUNT([ride_id]) }' />
      </column>
      <column caption='Signup_month' datatype='datetime' name='[Calculation_5633260797259781]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [created_at])' />
      </column>
      <column caption='MoM Growth %' datatype='real' name='[Calculation_5633260797648902]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNT([user_id (users.csv)]) - LOOKUP(COUNT([user_id (users.csv)]), -1)) /&#10;ABS(LOOKUP(COUNT([user_id (users.csv)]), -1)) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
