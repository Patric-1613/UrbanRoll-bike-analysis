    <worksheet name='ride_categories'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Ride Duration Breakdown</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='rides+' name='federated.0qe18wa19hozqz103e0xt1q5ix9f' />
          </datasources>
          <datasource-dependencies datasource='federated.0qe18wa19hozqz103e0xt1q5ix9f'>
            <column caption='Ride Category' datatype='string' name='[Calculation_5633260301918208]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF DATEDIFF(&apos;minute&apos;,[start_time],[end_time]) &lt;= 10 THEN &quot;Short (0-10 min)&quot;&#10;ELSEIF DATEDIFF(&apos;minute&apos;,[start_time],[end_time]) &lt;= 30 THEN &quot;Medium (11-30 min)&quot;&#10;ELSE &quot;Long (30+ min)&quot;&#10;END' />
            </column>
